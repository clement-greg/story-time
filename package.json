{
  "name": "story-time",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server/index.js",
    "server": "npx nodemon --exec ts-node server/index.ts --watch server --watch shared --ext ts,json",
    "server:build": "npx tsc",
    "client": "cd client && npx ng serve --proxy-config proxy.conf.json --port 6258",
    "build": "npx tsc && cd client && npm run build",
    "predev": "npx kill-port 3200 6258",
    "dev": "concurrently --kill-others \"npm run server\" \"npm run client\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@azure/cosmos": "^4.9.2",
    "@azure/openai": "^2.0.0",
    "@azure/storage-blob": "^12.31.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
